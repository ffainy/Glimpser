{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.0.0",
  "description": "__MSG_extDescription__",
  "author": "farfaraway",
  "homepage_url": "https://github.com/ffainy/glimpser",
  "default_locale": "en",
  "action": {
    "default_title": "Glimpser"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "permissions": [
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["i18n.js", "settings-panel.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "glimpser@extension",
      "strict_min_version": "109.0"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["_locales/*", "css/*.css", "icons/logo.svg"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
